# Required for AI generation/import/meal planning
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: official USDA FoodData Central API key for richer nutrition lookup later
USDA_FDC_API_KEY=your_usda_key_here

# Optional model override. Defaults to gpt-4o-mini for lower cost.
OPENAI_MODEL=gpt-4o-mini

# --- Upstash Redis (required for Vercel deployment) ---
# Add Upstash Redis integration in Vercel dashboard, then run: vercel env pull
# Or create a free database at https://console.upstash.com and paste the values below.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
